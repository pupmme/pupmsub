[Unit]
Description=sub Service
After=network.target nss-lookup.target
Wants=network.target

[Service]
User=root
Group=root
Type=simple
LimitAS=infinity
LimitRSS=infinity
LimitCORE=infinity
LimitNOFILE=999999
WorkingDirectory=/usr/local/sub/
ExecStart=/usr/local/sub/sub server
Restart=on-failure
RestartSec=10

[Install]
WantedBy=multi-user.target
